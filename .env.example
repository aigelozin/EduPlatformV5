# =============================================
# EduPlatform РФ — Environment Variables
# Скопировать в .env.local и заполнить
# НЕ коммитить .env.local в git
# =============================================

# ---- Application ----
NEXTAUTH_URL=https://yourdomain.ru
NEXTAUTH_SECRET=                          # openssl rand -base64 32
NEXT_PUBLIC_APP_URL=https://yourdomain.ru

# ---- Database (Beget PostgreSQL) ----
DATABASE_URL=postgresql://user:password@localhost:5432/eduplatform
TEST_DATABASE_URL=postgresql://user:password@localhost:5432/eduplatform_test

# ---- Яндекс Object Storage (YOS) ----
YOS_ACCESS_KEY_ID=
YOS_SECRET_ACCESS_KEY=
YOS_BUCKET_NAME=eduplatform-private
YOS_PUBLIC_BUCKET_NAME=eduplatform-public
YOS_ENDPOINT=https://storage.yandexcloud.net
YOS_REGION=ru-central1
NEXT_PUBLIC_YOS_PUBLIC_URL=https://storage.yandexcloud.net/eduplatform-public

# ---- Яндекс Managed Redis ----
REDIS_URL=redis://:password@rc1a-xxxx.mdb.yandexcloud.net:6379/0
REDIS_PASSWORD=

# ---- YooKassa ----
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_WEBHOOK_SECRET=

# ---- CryptoCloud ----
CRYPTOCLOUD_API_KEY=
CRYPTOCLOUD_SHOP_ID=
CRYPTOCLOUD_SECRET_KEY=

# ---- МИР Pay / НСПК ----
MIR_PAY_MERCHANT_ID=
MIR_PAY_SECRET_KEY=
MIR_PAY_API_URL=https://test.mirpay.ru

# ---- CDEK ----
CDEK_CLIENT_ID=
CDEK_CLIENT_SECRET=
CDEK_API_URL=https://api.edu.cdek.ru/v2
CDEK_WEBHOOK_SECRET=

# ---- Boxberry ----
BOXBERRY_TOKEN=
BOXBERRY_API_URL=

# ---- YandexGPT (primary AI) ----
YANDEXGPT_API_KEY=
YANDEXGPT_FOLDER_ID=
YANDEXGPT_MODEL=yandexgpt-lite

# ---- Claude API (AI fallback) ----
ANTHROPIC_API_KEY=
AI_CHAT_RATE_LIMIT_PER_HOUR=20

# ---- SendPulse (primary email) ----
SENDPULSE_API_USER_ID=
SENDPULSE_API_SECRET=
EMAIL_FROM=EduPlatform <noreply@yourdomain.ru>
EMAIL_SUPPORT=support@yourdomain.ru

# ---- Beget SMTP (backup email) ----
SMTP_HOST=mail.beget.com
SMTP_PORT=465
SMTP_USER=noreply@yourdomain.ru
SMTP_PASS=

# ---- GlitchTip (мониторинг ошибок) ----
GLITCHTIP_DSN=https://key@glitchtip.yourdomain.ru/1
NEXT_PUBLIC_GLITCHTIP_DSN=https://key@glitchtip.yourdomain.ru/1
GLITCHTIP_ENVIRONMENT=development

# ---- Business Logic ----
PLATFORM_FEE_PERCENT=20
SUBSCRIPTION_REMINDER_DAYS=3

# ---- Local Docker Dev (не для продакшна) ----
POSTGRES_USER=eduplatform
POSTGRES_PASSWORD=eduplatform_dev
POSTGRES_DB=eduplatform
