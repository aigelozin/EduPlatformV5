generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  admin
  teacher
  subscriber
  student
}

enum ProductType {
  lesson
  course
  bundle
  livestream
  digital_book
  physical_book
  souvenir
  apparel
  subscription_plan
}

enum VideoSource {
  vk
  rutube
  kinescope
  youtube
  yos
}

enum ModerationStatus {
  pending
  approved
  rejected
}

enum OrderStatus {
  pending
  paid
  shipped
  delivered
  cancelled
  refunded
}

enum PaymentStatus {
  pending
  succeeded
  failed
  cancelled
  refunded
}

enum PaymentProvider {
  yookassa
  cryptocloud
  mir_pay
}

enum DeliveryProvider {
  cdek
  boxberry
}

enum NotificationType {
  purchase
  subscription_expiry
  new_lesson
  payout
  system
}

// ─── Tables ───────────────────────────────────────────────────────────────────

model SiteSettings {
  id         String   @id @default("main")
  brand      Json?
  typography Json?
  homepage   Json?
  seo        Json?
  updated_at DateTime @updatedAt

  @@map("site_settings")
}

model Profile {
  id                    String   @id @default(cuid())
  email                 String   @unique
  password_hash         String?
  name                  String
  avatar_url            String?
  role                  Role     @default(student)
  bio_ru                String?  @db.Text
  bio_en                String?  @db.Text
  preferred_lang        String   @default("ru")
  is_active             Boolean  @default(true)
  city                  String?
  registration_ip       String?
  force_password_change Boolean  @default(false)
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  products              Product[]
  user_subscriptions    UserSubscription[]
  purchases             Purchase[]
  orders                Order[]
  reviews               Review[]
  user_progress         UserProgress[]
  consent_logs          ConsentLog[]
  ai_chat_sessions      AiChatSession[]
  notifications         Notification[]
  teacher_payouts       TeacherPayout[]
  product_messages      ProductMessage[]
  livestream_messages   LivestreamMessage[]
  category_links        Category[]           @relation("CategoryTeacher")

  @@map("profiles")
}

model Category {
  id             String    @id @default(cuid())
  slug           String    @unique
  name_ru        String
  name_en        String?
  description_ru String?
  brief_ru       String?
  icon_emoji     String?
  wave_color     String?
  wave_accent    String?
  parent_id      String?
  sub_type       String?
  teacher_id     String?
  sort_order     Int       @default(0)
  is_active      Boolean   @default(true)
  created_at     DateTime  @default(now())

  products  Product[]
  parent    Category?  @relation("CategoryChildren", fields: [parent_id], references: [id])
  children  Category[] @relation("CategoryChildren")
  teacher   Profile?   @relation("CategoryTeacher", fields: [teacher_id], references: [id])

  @@index([parent_id])
  @@index([teacher_id])
  @@map("categories")
}

model Product {
  id                String           @id @default(cuid())
  slug              String           @unique
  type              ProductType
  title_ru          String
  title_en          String?
  description_ru    String?  @db.Text
  description_en    String?  @db.Text
  seo_title_ru      String?
  seo_description_ru String? @db.Text
  ai_description_ru String?  @db.Text
  views_count       Int              @default(0)
  duration_minutes  Int?
  price             Int              // в копейках
  sale_price        Int?
  thumbnail_url     String?
  preview_video_url String?
  video_source      VideoSource?
  video_id          String?
  moderation_status ModerationStatus @default(pending)
  is_active         Boolean          @default(false)
  creator_id        String
  category_id       String?
  created_at        DateTime         @default(now())
  updated_at        DateTime         @updatedAt

  creator           Profile          @relation(fields: [creator_id], references: [id])
  category          Category?        @relation(fields: [category_id], references: [id])
  variants          ProductVariant[]
  lessons           Lesson[]
  courses           CourseProduct[]  @relation("CourseToProduct")
  course_lessons    CourseProduct[]  @relation("ProductInCourse")
  bundles           BundleProduct[]  @relation("BundleToProduct")
  bundle_items      BundleProduct[]  @relation("ProductInBundle")
  purchases         Purchase[]
  order_items       OrderItem[]
  reviews           Review[]
  user_progress     UserProgress[]
  subscriptions     Subscription[]
  product_messages  ProductMessage[]

  @@index([creator_id])
  @@index([category_id])
  @@index([type, is_active])
  @@map("products")
}

model ProductMessage {
  id         String   @id @default(cuid())
  product_id String
  user_id    String
  body_ru    String   @db.Text
  is_pinned  Boolean  @default(false)
  is_deleted Boolean  @default(false)
  deleted_by String?
  created_at DateTime @default(now())

  product    Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)
  user       Profile  @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([product_id, created_at])
  @@map("product_messages")
}

model ProductVariant {
  id         String   @id @default(cuid())
  product_id String
  name_ru    String
  sku        String?  @unique
  price      Int
  stock      Int      @default(0)
  attributes Json?    // { size: "L", color: "black" }
  created_at DateTime @default(now())

  product    Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@index([product_id])
  @@map("product_variants")
}

model Lesson {
  id           String      @id @default(cuid())
  product_id   String
  title_ru     String
  title_en     String?
  description_ru String? @db.Text
  video_source VideoSource?
  video_id     String?
  yos_key      String?     // ключ в Яндекс Object Storage
  duration_sec Int?
  sort_order   Int         @default(0)
  is_free      Boolean     @default(false)
  created_at   DateTime    @default(now())
  updated_at   DateTime    @updatedAt

  product      Product     @relation(fields: [product_id], references: [id], onDelete: Cascade)
  user_progress UserProgress[]

  @@index([product_id])
  @@map("lessons")
}

model CourseProduct {
  course_id  String
  product_id String
  sort_order Int     @default(0)

  course     Product @relation("CourseToProduct", fields: [course_id], references: [id], onDelete: Cascade)
  product    Product @relation("ProductInCourse", fields: [product_id], references: [id], onDelete: Cascade)

  @@id([course_id, product_id])
  @@map("courses")
}

// Self-referencing through pivot for bundles
model BundleProduct {
  bundle_id  String
  product_id String

  bundle     Product @relation("BundleToProduct", fields: [bundle_id], references: [id], onDelete: Cascade)
  product    Product @relation("ProductInBundle", fields: [product_id], references: [id], onDelete: Cascade)

  @@id([bundle_id, product_id])
  @@map("bundles")
}

model Livestream {
  id              String    @id @default(cuid())
  product_id      String    @unique
  stream_url      String?   @db.Text
  scheduled_at    DateTime
  ended_at        DateTime?
  recording_url   String?   @db.Text
  recording_source    VideoSource?
  created_at          DateTime  @default(now())

  livestream_messages LivestreamMessage[]

  @@map("livestreams")
}

model LivestreamMessage {
  id            String     @id @default(cuid())
  livestream_id String
  user_id       String
  body_ru       String     @db.Text
  is_deleted    Boolean    @default(false)
  deleted_by    String?
  created_at    DateTime   @default(now())

  livestream    Livestream @relation(fields: [livestream_id], references: [id], onDelete: Cascade)
  user          Profile    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([livestream_id, created_at])
  @@map("livestream_messages")
}

model Subscription {
  id          String   @id @default(cuid())
  product_id  String
  name_ru     String
  duration_days Int
  price       Int      // в копейках
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())

  product     Product  @relation(fields: [product_id], references: [id])
  user_subscriptions UserSubscription[]

  @@index([product_id])
  @@map("subscriptions")
}

model UserSubscription {
  id              String    @id @default(cuid())
  user_id         String
  subscription_id String
  starts_at       DateTime  @default(now())
  expires_at      DateTime
  is_active       Boolean   @default(true)
  created_at      DateTime  @default(now())

  user            Profile      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  subscription    Subscription @relation(fields: [subscription_id], references: [id], onDelete: Cascade)

  @@index([user_id, expires_at])
  @@map("user_subscriptions")
}

model Purchase {
  id         String   @id @default(cuid())
  user_id    String
  product_id String
  amount     Int      // в копейках
  created_at DateTime @default(now())

  user       Profile  @relation(fields: [user_id], references: [id])
  product    Product  @relation(fields: [product_id], references: [id])

  @@unique([user_id, product_id])
  @@index([user_id])
  @@map("purchases")
}

model Order {
  id              String      @id @default(cuid())
  user_id         String
  status          OrderStatus @default(pending)
  total_amount    Int         // в копейках
  delivery_amount Int         @default(0)
  delivery_address Json?
  delivery_provider DeliveryProvider?
  delivery_tracking String?
  created_at      DateTime    @default(now())
  updated_at      DateTime    @updatedAt

  user            Profile     @relation(fields: [user_id], references: [id])
  items           OrderItem[]
  payments        Payment[]

  @@index([user_id])
  @@map("orders")
}

model OrderItem {
  id          String  @id @default(cuid())
  order_id    String
  product_id  String
  variant_id  String?
  quantity    Int     @default(1)
  price       Int     // в копейках, цена на момент покупки

  order       Order   @relation(fields: [order_id], references: [id], onDelete: Cascade)
  product     Product @relation(fields: [product_id], references: [id])

  @@index([order_id])
  @@map("order_items")
}

model Payment {
  id               String          @id @default(cuid())
  order_id         String
  provider         PaymentProvider
  provider_payment_id String?      @unique
  status           PaymentStatus   @default(pending)
  amount           Int             // в копейках
  currency         String          @default("RUB")
  metadata         Json?
  created_at       DateTime        @default(now())
  updated_at       DateTime        @updatedAt

  order            Order           @relation(fields: [order_id], references: [id])

  @@index([order_id])
  @@index([provider_payment_id])
  @@map("payments")
}

model TeacherPayout {
  id           String   @id @default(cuid())
  teacher_id   String
  amount       Int      // в копейках
  period_start DateTime
  period_end   DateTime
  status       String   @default("pending")
  paid_at      DateTime?
  created_at   DateTime @default(now())

  teacher      Profile  @relation(fields: [teacher_id], references: [id])

  @@index([teacher_id])
  @@map("teacher_payouts")
}

model PaymentMethodsConfig {
  id         String          @id @default(cuid())
  provider   PaymentProvider @unique
  is_active  Boolean         @default(true)
  config     Json?
  updated_at DateTime        @updatedAt

  @@map("payment_methods_config")
}

model DeliveryQuote {
  id              String          @id @default(cuid())
  order_id        String?
  provider        DeliveryProvider
  from_city       String
  to_city         String
  weight_g        Int
  amount          Int             // в копейках
  estimated_days  Int?
  expires_at      DateTime
  created_at      DateTime        @default(now())

  @@index([order_id])
  @@map("delivery_quotes")
}

model UserProgress {
  id            String   @id @default(cuid())
  user_id       String
  product_id    String
  lesson_id     String?
  progress_pct  Int      @default(0)  // 0-100
  completed_at  DateTime?
  updated_at    DateTime @updatedAt

  user          Profile  @relation(fields: [user_id], references: [id])
  product       Product  @relation(fields: [product_id], references: [id])
  lesson        Lesson?  @relation(fields: [lesson_id], references: [id])

  @@unique([user_id, lesson_id])
  @@index([user_id, product_id])
  @@map("user_progress")
}

model Review {
  id         String   @id @default(cuid())
  user_id    String
  product_id String
  rating     Int      // 1-5
  text_ru    String?  @db.Text
  reply_ru   String?  @db.Text
  replied_at DateTime?
  is_visible Boolean  @default(true)
  created_at DateTime @default(now())

  user       Profile  @relation(fields: [user_id], references: [id])
  product    Product  @relation(fields: [product_id], references: [id])

  @@unique([user_id, product_id])
  @@index([product_id])
  @@map("reviews")
}

model ConsentLog {
  id         String   @id @default(cuid())
  user_id    String
  consent_type String // "registration" | "checkout" | "become_teacher"
  ip_address String?
  user_agent String?  @db.Text
  created_at DateTime @default(now())

  user       Profile  @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@map("consent_log")
}

model AiChatSession {
  id         String   @id @default(cuid())
  user_id    String
  messages   Json?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user       Profile  @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@map("ai_chat_sessions")
}

model Notification {
  id         String           @id @default(cuid())
  user_id    String
  type       NotificationType
  title_ru   String
  body_ru    String?  @db.Text
  is_read    Boolean          @default(false)
  data       Json?
  created_at DateTime         @default(now())

  user       Profile          @relation(fields: [user_id], references: [id])

  @@index([user_id, is_read])
  @@map("notifications")
}
